# Copy to .env and edit before running ./init.sh.

COMPOSE_PROJECT_NAME=mcqq-bridge

# The address your BDS machine can use to reach Bridge.
# If BDS runs on the same Docker host, use the host LAN IP, not 127.0.0.1.
BRIDGE_PUBLIC_URL=http://YOUR_SERVER_IP:8080

# QQ group to bridge.
QQ_GROUP_ID=123456789

# Empty means every QQ group text message is sent to MC.
# Set to /mc if you want command-style forwarding.
QQ_FORWARD_PREFIX=

# Optional. Leave empty to use the auto-generated token from data/config.yml.
ONEBOT_ACCESS_TOKEN=

# Bridge writes data/config.yml, logs, and generated behavior packs as this host user/group.
BRIDGE_UID=1000
BRIDGE_GID=1000

# NapCat Docker runs as this host user/group for persisted files.
NAPCAT_UID=1000
NAPCAT_GID=1000
